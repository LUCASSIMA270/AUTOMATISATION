    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet newsText = \"RAPPORT DE VEILLE MULTIPOLAIRE :\\n\\n\";\n\nfor (const item of items) {\n  // On récupère l'étiquette qu'on a créée à l'étape précédente\n  const blocNom = item.json.bloc || \"International\"; \n  const titre = item.json.title || \"Sans titre\";\n  const resume = item.json.contentSnippet || item.json.content || \"Pas de résumé disponible\";\n\n  newsText += `[ZONE: ${blocNom.toUpperCase()}]\\n`;\n  newsText += `TITRE: ${titre}\\n`;\n  newsText += `ANALYSE BRUTE: ${resume.substring(0, 300)}...\\n`;\n  newsText += `-------------------------------------------\\n\\n`;\n}\n\nreturn [{ json: { newsData: newsText } }];"
      },
